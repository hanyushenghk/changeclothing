# Optional: Google Gemini for garment category detection (otherwise deterministic fallback).
GEMINI_API_KEY=
GEMINI_TRYON_MODEL=gemini-1.5-flash

# Optional: Volcengine Ark (Doubao Seedream) for try-on generation (otherwise placeholder).
ARK_API_KEY=
DOUBAO_MODEL=doubao-seedream-4-5-251128

# Optional: Cloudflare Turnstile (bot protection for auth form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Supabase — https://supabase.com/dashboard
# Project URL: Settings → General → 有 "Project URL"（形如 https://xxxxx.supabase.co）
#   或点顶部 **Connect** 弹窗里也会显示。
# 浏览器端密钥（二选一，填到 NEXT_PUBLIC_SUPABASE_ANON_KEY）：
#   - 新版：**Publishable key**（常以 sb_publishable_ 开头）
#   - 或 API Keys 页里的 **Legacy API keys** 标签 → **anon** / public（常以 eyJ 开头）
# 切勿把 Secret key / service_role 写进 NEXT_PUBLIC_（那是服务端密钥）。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only（可选）：Secret key 或 legacy service_role，仅服务端脚本使用
SUPABASE_SERVICE_ROLE_KEY=
